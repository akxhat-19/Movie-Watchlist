# Virtual environment
venv/
.venv/
env/

# Python cache/bytecode
__pycache__/
*.pyc
*.pyo
*.pyd

# Git
.git/
.gitignore

# Environment variables (never bake secrets into an image)
.env

# IDE/editor files
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Docker itself
Dockerfile
.dockerignore

# Testing
.pytest_cache/
htmlcov/
.coverage

# Logs
*.log

# Local database (if you don't want to ship your dev DB inside the image)
*.db